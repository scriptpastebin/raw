local function FlyTo(nPCS)
	TargetPos = nPCS
	RunService:BindToRenderStep("BuyFly", Enum.RenderPriority.Character.Value + 1, function()
		if not _G.BuyFly then StopFly() return end
		local hRPResult4 = HRP()
