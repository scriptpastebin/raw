    BloxFruit = false,
}
local function AddPoint(Stat, Amount)
    pcall(function()
        CommF:InvokeServer("AddPoint", Stat, Amount, false)
    end)
end
local function DistributePoints()
    while AutoStats do
        task.wait(0.4)
        local player = game.Players.LocalPlayer
        local Data = player:FindFirstChild("Data")
        if not Data then continue end
        
        local points = Data:FindFirstChild("Points")
        if not points or points.Value <= 0 then continue end
        
        -- Ver quantos Stats estÃ£o ativos
        local EnabledStats = {}
        for stat, enabled in pairs(StatsSelect) do
            if enabled then
                table.insert(EnabledStats, stat)
            end
        end
        
        if #EnabledStats > 0 then
            local floor4 = math.floor(PointsPerTick / #EnabledStats)
            if floor4 < 1 then floor4 = 1 end
            
            for addSection38, stat in ipairs(EnabledStats) do
                AddPoint(stat, floor4)
            end
        end
    end
end
