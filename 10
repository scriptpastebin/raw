function GetNewServer()
    local Servers = {}
    
    local httpGet = game:HttpGet(
        "https://games.roblox.com/next/games/"..PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
    )
    
    local data = HttpService:JSONDecode(httpGet)
    for addSection48, server in pairs(data.data) do
        if server.playing < server.maxPlayers and server.id ~= JobId then
            table.insert(Servers, server.id)
        end
    end
    if #Servers > 0 then
        return Servers[math.random(1, #Servers)]
    end
end
