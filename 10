		EnsureFly()
		for addSection42,v in ipairs(localPlayer14.Character:GetDescendants()) do
			if v:IsA("BasePart") then v.CanCollide = false end
		end
		local delta = TargetPos - hRPResult4.Position
		local dist = delta.Magnitude
		if dist <= 3 then
			LV.VectorVelocity = Vector3.zero
			hRPResult4.AssemblyLinearVelocity = Vector3.zero
			hRPResult4.CFrame = CFrame.new(TargetPos)
			return
		end
		local unit = delta.Unit
		LV.VectorVelocity = unit * math.clamp(dist * 6, 120, 330)
		AO.CFrame = CFrame.lookAt(hRPResult4.Position, hRPResult4.Position + unit)
	end)
