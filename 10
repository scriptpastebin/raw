-- ===============================
-- FUNÇÃO DE ATUALIZAÇÃO (COMPATÍVEL COM SUA LÓGICA)
-- ===============================
local function UpdateAimbot()
    if not AimbotEnabled then
        loaded2:SetPlayerSilentAim(false)
        loaded2:SetNPCSilentAim(false)
        return
    end
    -- Se estiver mirando players
    if AimPlayers then
        loaded2:SetPlayerSilentAim(true)
        loaded2:SetNPCSilentAim(false)
        return
    end
    -- Se estiver mirando mobs
    if AimMobs then
        if IgnoreMobs then
            loaded2:SetNPCSilentAim(false)
        else
            loaded2:SetNPCSilentAim(true)
        end
        loaded2:SetPlayerSilentAim(false)
        return
    end
    -- fallback de segurança
    loaded2:SetPlayerSilentAim(false)
    loaded2:SetNPCSilentAim(false)
end
